{
  "name": "auth-engine",
  "version": "0.0.1",
  "description": "A microservice with nest framework, typeorm, apache kafka and kubernetes.",
  "license": "MIT",
  "author": "Newerton Vargas de Araujo",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest --config ./test/unit/jest.config.ts",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage --silent --config ./test/unit/jest.config.ts",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/e2e/jest.config.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@nestjs/axios": "4.0.1",
    "@nestjs/common": "11.1.27",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "11.1.27",
    "@nestjs/microservices": "11.1.27",
    "@nestjs/platform-express": "11.1.27",
    "env-var": "7.5.0",
    "kafkajs": "2.2.4",
    "lightship": "9.0.4",
    "rxjs": "7.8.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "21.1.0",
    "@commitlint/config-conventional": "21.1.0",
    "@nestjs/cli": "11.0.23",
    "@nestjs/schematics": "11.1.0",
    "@nestjs/testing": "11.1.27",
    "@swc/cli": "0.8.1",
    "@swc/core": "1.15.43",
    "@swc/jest": "0.2.39",
    "@types/express": "5.0.6",
    "@types/jest": "30.0.0",
    "@types/node": "26.0.1",
    "@types/supertest": "7.2.0",
    "husky": "9.1.7",
    "jest": "30.4.2",
    "prettier": "3.9.3",
    "supertest": "7.2.2",
    "ts-jest": "29.4.11",
    "ts-loader": "9.6.2",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "6.0.3"
  },
  "allowScripts": {
    "unrs-resolver@1.12.2": true,
    "@swc/core@1.15.43": true
  },
  "overrides": {
    "@babel/core": "^7.29.1",
    "brace-expansion": "^2.0.4",
    "diff": "^4.0.4",
    "js-yaml": "^4.3.0",
    "multer": "^2.1.2",
    "piscina": "^4.9.3"
  }
}